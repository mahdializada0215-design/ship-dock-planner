<div class="container">
  <h1>PACK HC BALANCER</h1>
  <div class="subtitle">9.5 hr shift | 9 hrs active | 30 min clean/other</div>

  <div class="params-bar">
    <div class="param-item"><div class="param-label">Singles UPH</div><div class="param-value">68</div></div>
    <div class="param-item"><div class="param-label">Multi UPH</div><div class="param-value">100</div></div>
    <div class="param-item"><div class="param-label">Active Hrs</div><div class="param-value">9.0</div></div>
    <div class="param-item"><div class="param-label">Singles Cap/HC</div><div class="param-value">612</div></div>
    <div class="param-item"><div class="param-label">Multi Cap/HC</div><div class="param-value">900</div></div>
  </div>

  <!-- INPUT SECTION -->
  <div class="section">
    <h2 class="gold">VOLUME &amp; HC INPUT</h2>
    <div class="input-row">
      <div class="input-group">
        <label>Singles Volume</label>
        <input type="number" id="singlesVol" placeholder="e.g. 2000" oninput="recalc()">
      </div>
      <div class="input-group">
        <label>Multi Volume</label>
        <input type="number" id="multiVol" placeholder="e.g. 1800" oninput="recalc()">
      </div>
      <div class="input-group">
        <label>Available HC (Direct)</label>
        <input type="number" id="availHC" placeholder="e.g. 8" oninput="recalc()">
      </div>
    </div>
  </div>

  <!-- SUMMARY -->
  <div class="section">
    <h2 class="green">HC PLAN SUMMARY</h2>
    <div class="summary-grid">
      <div class="summary-card">
        <div class="card-label">Singles HC Need</div>
        <div class="card-value" id="sHCNeed">—</div>
        <div class="card-sub" id="sHCSub"></div>
      </div>
      <div class="summary-card">
        <div class="card-label">Multi HC Need</div>
        <div class="card-value" id="mHCNeed">—</div>
        <div class="card-sub" id="mHCSub"></div>
      </div>
      <div class="summary-card">
        <div class="card-label">Day Target</div>
        <div class="card-value" id="dayTarget">—</div>
        <div class="card-sub">singles + multi</div>
      </div>
      <div class="summary-card">
        <div class="card-label">Total HC Need</div>
        <div class="card-value" id="totalNeed">—</div>
        <div class="card-sub">direct only</div>
      </div>
      <div class="summary-card highlight">
        <div class="card-label">HC Gap</div>
        <div class="card-value green" id="hcGap">—</div>
        <div class="card-sub" id="gapSub"></div>
      </div>
    </div>
  </div>

  <!-- HOURLY BALANCER TABLE -->
  <div class="section">
    <h2 class="orange">HOURLY HC BALANCE</h2>
    <p style="font-size:0.75rem; color:#888; margin-bottom:12px;">Edit Singles/Multi HC per hour to flex based on WIP. Totals update live.</p>
    <table class="hourly-table">
      <thead>
        <tr>
          <th>Hour</th>
          <th>Singles HC</th>
          <th>Multi HC</th>
          <th>Total HC</th>
          <th>Singles/hr</th>
          <th>Multi/hr</th>
          <th>Total/hr</th>
          <th>Cumulative</th>
        </tr>
      </thead>
      <tbody id="hourlyBody"></tbody>
    </table>
  </div>

  <!-- FLEX TRIGGERS -->
  <div class="section">
    <h2 class="blue">FLEX TRIGGERS</h2>
    <div class="flex-triggers">
      <div class="trigger-card">
        <h4>Move HC to Multi</h4>
        <ul>
          <li>Multi WIP &gt; 30 min of work</li>
          <li>Singles WIP &lt; 15 min (starving)</li>
          <li>Multi CPTs approaching</li>
          <li>Multi backlog from upstream</li>
        </ul>
      </div>
      <div class="trigger-card">
        <h4>Move HC to Singles</h4>
        <ul>
          <li>Singles WIP &gt; 30 min of work</li>
          <li>Multi WIP &lt; 15 min (drying up)</li>
          <li>End of shift - flush singles</li>
          <li>Singles CPTs at risk</li>
        </ul>
      </div>
    </div>
    <div class="notes">
      <strong>Key:</strong> Multi is 1.5x more productive per HC (100 vs 68 UPH). Each HC moved Singles to Multi = +32 units/hr.
      Bias toward Multi when volume allows, but never starve Singles WIP. Adjust hourly based on real-time WIP and CPT pressure.
    </div>
  </div>
</div>

<script>
var singlesUPH = 68;
var multiUPH = 100;
var activeHrs = 9;
var singlesCap = singlesUPH * activeHrs; // 612
var multiCap = multiUPH * activeHrs;     // 900

function buildTable(sHC, mHC) {
  var body = document.getElementById('hourlyBody');
  var html = '';
  var cumulative = 0;

  for (var h = 1; h <= 9; h++) {
    var sDefault = sHC;
    var mDefault = mHC;
    var sTput = sDefault * singlesUPH;
    var mTput = mDefault * multiUPH;
    var total = sTput + mTput;
    cumulative += total;
    var totalHC = sDefault + mDefault;

    html += '<tr class="hour-row">' +
      '<td class="hour-label">Hour ' + h + '</td>' +
      '<td><input class="editable s-input" type="number" value="' + sDefault + '" data-hour="' + h + '" onchange="updateRow(this)"></td>' +
      '<td><input class="editable m-input" type="number" value="' + mDefault + '" data-hour="' + h + '" onchange="updateRow(this)"></td>' +
      '<td class="row-total-hc">' + totalHC + '</td>' +
      '<td class="row-s-tput">' + sTput + '</td>' +
      '<td class="row-m-tput">' + mTput + '</td>' +
      '<td class="computed row-total-tput">' + total + '</td>' +
      '<td class="cumulative row-cum">' + cumulative.toLocaleString() + '</td>' +
      '</tr>';
  }

  // Total row
  html += '<tr class="total-row">' +
    '<td>PLAN OUTPUT</td><td></td><td></td><td></td><td id="totalSTput"></td><td id="totalMTput"></td>' +
    '<td id="totalTput"></td><td id="totalCum"></td></tr>';

  // Target row
  html += '<tr class="target-row">' +
    '<td>TARGET</td><td></td><td></td><td></td><td id="targetS"></td><td id="targetM"></td>' +
    '<td id="targetTotal"></td><td></td></tr>';

  // Diff row
  html += '<tr class="diff-row"><td>DIFF</td><td></td><td></td><td></td><td id="diffS"></td><td id="diffM"></td><td id="diffTotal"></td><td></td></tr>';

  body.innerHTML = html;
  recalcTable();
}

function updateRow(el) {
  recalcTable();
}

function recalcTable() {
  var rows = document.querySelectorAll('#hourlyBody tr.hour-row');
  var cumulative = 0;
  var totalS = 0, totalM = 0, totalAll = 0;

  rows.forEach(function(row) {
    var sInput = row.querySelector('.s-input');
    var mInput = row.querySelector('.m-input');
    if (!sInput || !mInput) return;
    var s = parseInt(sInput.value) || 0;
    var m = parseInt(mInput.value) || 0;
    var sTput = s * singlesUPH;
    var mTput = m * multiUPH;
    var total = sTput + mTput;
    cumulative += total;
    totalS += sTput;
    totalM += mTput;
    totalAll += total;

    row.querySelector('.row-total-hc').textContent = s + m;
    row.querySelector('.row-s-tput').textContent = sTput;
    row.querySelector('.row-m-tput').textContent = mTput;
    row.querySelector('.row-total-tput').textContent = total;
    row.querySelector('.row-cum').textContent = cumulative.toLocaleString();
  });

  document.getElementById('totalSTput').textContent = totalS.toLocaleString();
  document.getElementById('totalMTput').textContent = totalM.toLocaleString();
  document.getElementById('totalTput').textContent = totalAll.toLocaleString();
  document.getElementById('totalCum').textContent = cumulative.toLocaleString();

  // Update target row
  var singlesVol = parseInt(document.getElementById('singlesVol').value) || 0;
  var multiVol = parseInt(document.getElementById('multiVol').value) || 0;
  var targetTotal = singlesVol + multiVol;

  document.getElementById('targetS').textContent = singlesVol > 0 ? singlesVol.toLocaleString() : '\u2014';
  document.getElementById('targetM').textContent = multiVol > 0 ? multiVol.toLocaleString() : '\u2014';
  document.getElementById('targetTotal').textContent = targetTotal > 0 ? targetTotal.toLocaleString() : '\u2014';

  // Diff row
  var diffS = totalS - singlesVol;
  var diffM = totalM - multiVol;
  var diffAll = cumulative - targetTotal;

  function formatDiff(val) {
    if (val === 0) return '0';
    var prefix = val > 0 ? '+' : '';
    return '<span style="color:' + (val >= 0 ? '#00d4aa' : '#ff5555') + '">' + prefix + val.toLocaleString() + '</span>';
  }

  if (targetTotal > 0) {
    document.getElementById('diffS').innerHTML = singlesVol > 0 ? formatDiff(diffS) : '\u2014';
    document.getElementById('diffM').innerHTML = multiVol > 0 ? formatDiff(diffM) : '\u2014';
    document.getElementById('diffTotal').innerHTML = formatDiff(diffAll);
  }
}

function recalc() {
  var singlesVol = parseInt(document.getElementById('singlesVol').value) || 0;
  var multiVol = parseInt(document.getElementById('multiVol').value) || 0;
  var availHC = parseInt(document.getElementById('availHC').value) || 0;

  // Use floor for each, then check if combined output covers target
  // If not, add 1 HC to the process with the smaller gap (flex logic)
  var sHCNeed = singlesVol > 0 ? Math.floor(singlesVol / singlesCap) : 0;
  var mHCNeed = multiVol > 0 ? Math.floor(multiVol / multiCap) : 0;
  var sOutput = sHCNeed * singlesCap;
  var mOutput = mHCNeed * multiCap;
  var sGap = singlesVol - sOutput;
  var mGap = multiVol - mOutput;
  // If there's remaining volume, add 1 HC — but only 1, since that person can flex
  if ((sGap + mGap) > 0) { sHCNeed += 1; }

  var totalNeed = sHCNeed + mHCNeed;
  var dayTarget = singlesVol + multiVol;
  var gap = availHC - totalNeed;

  document.getElementById('dayTarget').textContent = dayTarget > 0 ? dayTarget.toLocaleString() : '\u2014';

  document.getElementById('sHCNeed').textContent = (singlesVol > 0) ? sHCNeed : '\u2014';
  document.getElementById('sHCSub').textContent = (singlesVol > 0) ? singlesVol + ' \u00F7 612' : '';
  document.getElementById('mHCNeed').textContent = (multiVol > 0) ? mHCNeed : '\u2014';
  document.getElementById('mHCSub').textContent = (multiVol > 0) ? multiVol + ' \u00F7 900' : '';
  document.getElementById('totalNeed').textContent = (singlesVol > 0 || multiVol > 0) ? totalNeed : '\u2014';

  if (availHC > 0 && totalNeed > 0) {
    document.getElementById('hcGap').textContent = gap >= 0 ? '+' + gap : gap;
    document.getElementById('hcGap').style.color = gap >= 0 ? '#00d4aa' : '#ff5555';
    document.getElementById('gapSub').textContent = gap >= 0 ? 'extra' : 'short';
  } else {
    document.getElementById('hcGap').textContent = '\u2014';
    document.getElementById('hcGap').style.color = '#00d4aa';
    document.getElementById('gapSub').textContent = '';
  }

  // Distribute HC for the hourly table
  var sHC = sHCNeed;
  var mHC = mHCNeed; 
  // If not enough HC available, scale proportionally biasing Multi
  if (availHC > 0 && totalNeed > 0 && availHC < totalNeed) {
      // not enough HC, distribute proportionally biasing Multi
      var ratio = availHC / totalNeed; 
      mHC = Math.ceil(mHCNeed * ratio);
      sHC = availHC - mHC;
      if (sHC < 0) { sHC = 0; mHC = availHC; }
  } else if (availHC > 0 && totalNeed === 0) {
    sHC = Math.floor(availHC * 0.6);
    mHC = availHC - sHC;
  }

  buildTable(sHC, mHC);
}

// Init with empty table
buildTable(5, 3);
</script>


