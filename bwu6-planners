<title>Pack HC Balancer</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #1a1a2e;
    color: #e0e0e0;
    padding: 20px;
    min-height: 100vh;
  }
  .container { max-width: 850px; margin: 0 auto; }
  h1 { text-align: center; font-size: 1.5rem; margin-bottom: 4px; color: #fff; }
  .subtitle { text-align: center; font-size: 0.8rem; color: #888; margin-bottom: 20px; }

  .params-bar {
    display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;
    background: #16213e; border-radius: 10px; padding: 10px 16px; margin-bottom: 20px;
  }
  .param-item { text-align: center; }
  .param-label { font-size: 0.65rem; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }
  .param-value { font-size: 1rem; font-weight: 700; color: #00d4aa; }

  .section {
    background: #16213e; border-radius: 12px; padding: 20px; margin-bottom: 16px;
  }
  .section h2 { font-size: 0.95rem; margin-bottom: 14px; }
  .section h2.gold { color: #ffd700; }
  .section h2.green { color: #00d4aa; }
  .section h2.orange { color: #ffa500; }
  .section h2.blue { color: #5dade2; }

  .input-row {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-bottom: 12px;
  }
  .input-group { display: flex; flex-direction: column; }
  .input-group label {
    font-size: 0.7rem; color: #aaa; margin-bottom: 4px;
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .input-group input, .input-group select {
    background: #0f3460; border: 2px solid #1a4a7a; border-radius: 8px;
    padding: 10px 12px; font-size: 1.1rem; font-weight: 700; color: #fff;
    text-align: center; transition: border-color 0.2s;
  }
  .input-group input:focus, .input-group select:focus { outline: none; border-color: #00d4aa; }
  .input-group input::placeholder { color: #555; }

  .summary-grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; margin-bottom: 14px;
  }
  .summary-card {
    background: #0f3460; border-radius: 8px; padding: 12px; text-align: center;
  }
  .summary-card.highlight { background: linear-gradient(135deg, #0f3460, #1a5a3a); border: 1px solid #00d4aa; }
  .summary-card .card-label { font-size: 0.65rem; color: #888; text-transform: uppercase; margin-bottom: 2px; }
  .summary-card .card-value { font-size: 1.5rem; font-weight: 800; color: #fff; }
  .summary-card .card-value.green { color: #00d4aa; }
  .summary-card .card-sub { font-size: 0.65rem; color: #666; margin-top: 2px; }

  .hourly-table {
    width: 100%; border-collapse: collapse; font-size: 0.8rem;
  }
  .hourly-table th {
    background: #0d1b3e; padding: 8px 6px; text-align: center;
    color: #aaa; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.3px;
    border-bottom: 2px solid #1a4a7a;
  }
  .hourly-table td {
    padding: 8px 6px; text-align: center; border-bottom: 1px solid #1a2a4a;
  }
  .hourly-table tr:hover { background: #1a2a5a; }
  .hourly-table .hour-label { color: #aaa; font-weight: 600; text-align: left; }
  .hourly-table .editable {
    background: #0f3460; border: 1px solid #1a4a7a; border-radius: 4px;
    color: #fff; font-weight: 700; width: 44px; text-align: center; padding: 4px;
    font-size: 0.85rem;
  }
  .hourly-table .editable:focus { border-color: #00d4aa; outline: none; }
  .hourly-table .computed { color: #00d4aa; font-weight: 700; }
  .hourly-table .cumulative { color: #ffa500; font-weight: 600; }
  .hourly-table tr.total-row { background: #0d1b3e; border-top: 2px solid #00d4aa; }
  .hourly-table tr.total-row td { font-weight: 800; color: #00d4aa; padding: 10px 6px; }

  .hourly-table tr.target-row { background: #2a1a3e; border-top: 2px solid #ffd700; }
  .hourly-table tr.target-row td { font-weight: 700; color: #ffd700; padding: 10px 6px; }
  .hourly-table tr.diff-row td { font-weight: 600; font-size: 0.75rem; }

  .status-bar {
    margin-top: 14px; padding: 12px; border-radius: 8px; font-size: 0.85rem; font-weight: 600;
  }
  .status-bar.on-track { background: #1a3a2a; border: 1px solid #00d4aa; color: #00d4aa; }
  .status-bar.behind { background: #3a2a1a; border: 1px solid #ffa500; color: #ffa500; }
  .status-bar.over { background: #3a1a1a; border: 1px solid #ff5555; color: #ff5555; }

  .notes {
    margin-top: 14px; padding: 12px; background: #0d1b3e; border-radius: 8px;
    border-left: 3px solid #ffd700; font-size: 0.75rem; color: #bbb; line-height: 1.5;
  }

  .flex-triggers {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 14px;
  }
  .trigger-card {
    background: #0d1b3e; border-radius: 8px; padding: 12px;
  }
  .trigger-card h4 { font-size: 0.75rem; color: #ffa500; margin-bottom: 6px; text-transform: uppercase; }
  .trigger-card ul { list-style: none; padding: 0; }
  .trigger-card ul li { font-size: 0.75rem; color: #bbb; padding: 3px 0; padding-left: 12px; position: relative; }
  .trigger-card ul li::before { content: ">"; position: absolute; left: 0; color: #00d4aa; }
</style>
